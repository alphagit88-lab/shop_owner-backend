# ─── Neon PostgreSQL ───────────────────────────────────────────────
# Get this from: https://console.neon.tech → Your Project → Connection Details
# Choose "Connection string" → copy the pooled connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/jewellery?sslmode=require

# ─── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── SendGrid ──────────────────────────────────────────────────────
# Get from: https://app.sendgrid.com → Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# The verified sender email in your SendGrid account
SENDGRID_FROM_EMAIL=shop@yourdomain.com
SENDGRID_FROM_NAME=Gem Palace Jewelry

# ─── App ───────────────────────────────────────────────────────────
PORT=4000
SHOP_NAME=Gem Palace Jewelry
NODE_ENV=development

# ─── Frontend URL (for CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000
